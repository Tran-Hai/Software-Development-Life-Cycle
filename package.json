{
  "name": "sdlc-platform",
  "private": true,
  "scripts": {
    "dev": "cd packages/frontend && npm run dev",
    "build": "cd packages/frontend && npm run build",
    "start": "cd packages/frontend && npm run start",
    "lint": "cd packages/frontend && npm run lint",
    "typecheck": "cd packages/frontend && npm run typecheck",
    "prisma:generate": "cd packages/frontend && npx prisma generate",
    "prisma:migrate": "cd packages/frontend && npx prisma migrate dev",
    "prisma:studio": "cd packages/frontend && npx prisma studio",
    "db:seed": "cd packages/frontend && npx prisma db seed"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
