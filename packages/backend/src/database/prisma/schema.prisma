generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USER MANAGEMENT ====================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String    @map("full_name")
  avatarUrl     String?   @map("avatar_url")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  refreshTokens       RefreshToken[]
  userRoles           UserRole[]
  ownedOrganizations  Organization[] @relation("OrganizationOwner")
  memberships         Member[]
  authoredDocuments   Document[]     @relation("DocumentAuthor")
  reportedIssues      Issue[]        @relation("IssueReporter")
  assignedIssues      Issue[]        @relation("IssueAssignee")
  issueComments       IssueComment[]
  issueAttachments    IssueAttachment[]
  issueActivityLogs   IssueActivityLog[]
  authoredTestCases   TestCase[]
  executedTestRuns    TestRun[]      @relation("TestRunExecutor")
  executedTestResults TestResult[]   @relation("TestExecutor")
  reportedBugs        Bug[]          @relation("BugReporter")
  assignedBugs        Bug[]          @relation("BugAssignee")
  bugAttachments      BugAttachment[]
  activityLogs        ActivityLog[]
  notifications       Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  scope       String   // "platform" | "project"
  createdAt   DateTime @default(now()) @map("created_at")

  permissions RolePermission[]
  userRoles   UserRole[]
  members     Member[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String
  action      String   // "create" | "read" | "update" | "delete" | "manage"
  description String?

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId      String   @map("user_id")
  roleId      String   @map("role_id")
  projectId   String   @default("none") @map("project_id") // "none" = platform-level role
  assignedAt  DateTime @default(now()) @map("assigned_at")

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId, projectId])
  @@unique([userId, projectId], name: "UserRole_unique_user_project")
  @@map("user_roles")
}

// ==================== ORGANIZATION & PROJECT ====================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner    User      @relation("OrganizationOwner", fields: [ownerId], references: [id])
  projects Project[]

  @@map("organizations")
}

model Project {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  key            String   @unique // e.g. "PROJ", "SDLC"
  description    String?
  visibility     String   @default("private") // "private" | "internal" | "public"
  status         String   @default("active")  // "active" | "archived"
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  settings     ProjectSettings?
  members      Member[]
  sprints      Sprint[]
  epics        Epic[]
  issueTypes   IssueType[]
  issues       Issue[]
  documents    Document[]
  tags         IssueTag[]
  testSuites   TestSuite[]
  testCases    TestCase[]
  bugs         Bug[]
  pipelines    CIPipeline[]
  webhooks     Webhook[]
  activityLogs ActivityLog[]

  @@index([organizationId])
  @@map("projects")
}

model ProjectSettings {
  projectId           String  @id @map("project_id")
  defaultIssueType    String? @map("default_issue_type")
  sprintDurationDays  Int     @default(14) @map("sprint_duration_days")
  timezone            String  @default("UTC")
  customFields        Json?   @map("custom_fields")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_settings")
}

model Member {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  roleId    String   @map("role_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
  @@map("members")
}

// ==================== DOCUMENTS / WIKI ====================

model Document {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  parentId    String?  @map("parent_id")
  authorId    String   @map("author_id")
  title       String
  content     String?  @db.Text
  slug        String
  position    Int      @default(0)
  status      String   @default("draft") // "draft" | "published" | "archived"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")

  project  Project          @relation(fields: [projectId], references: [id])
  author   User             @relation("DocumentAuthor", fields: [authorId], references: [id])
  parent   Document?        @relation("DocumentHierarchy", fields: [parentId], references: [id])
  children Document[]       @relation("DocumentHierarchy")
  versions DocumentVersion[]
  comments DocumentComment[]

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("documents")
}

model DocumentVersion {
  id             String   @id @default(uuid())
  documentId     String   @map("document_id")
  authorId       String   @map("author_id")
  content        String   @db.Text
  changeSummary  String?  @map("change_summary")
  versionNumber  Int      @map("version_number")
  createdAt      DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_versions")
}

model DocumentComment {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  authorId   String   @map("author_id")
  content    String   @db.Text
  parentId   String?  @map("parent_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_comments")
}

// ==================== SPRINT & AGILE ====================

model Sprint {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  goal      String?
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  status    String   @default("planning") // "planning" | "active" | "completed" | "cancelled"
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])
  issues  Issue[]
  testRuns TestRun[]

  @@index([projectId])
  @@index([projectId, status])
  @@map("sprints")
}

model Epic {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  title       String
  description String?
  status      String   @default("backlog") // "backlog" | "in_progress" | "completed" | "cancelled"
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])
  issues  Issue[]

  @@index([projectId])
  @@map("epics")
}

// ==================== TASKS / ISSUES ====================

model IssueType {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String   // "task" | "bug" | "story" | "epic" | "subtask"
  icon      String?
  color     String?

  project Project @relation(fields: [projectId], references: [id])
  issues  Issue[]

  @@unique([projectId, name])
  @@map("issue_types")
}

model Issue {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  issueNumber   String   @map("issue_number") // "PROJ-123"
  issueTypeId   String   @map("issue_type_id")
  epicId        String?  @map("epic_id")
  sprintId      String?  @map("sprint_id")
  assigneeId    String?  @map("assignee_id")
  reporterId    String   @map("reporter_id")
  parentId      String?  @map("parent_id") // for subtasks
  title         String
  description   String?  @db.Text
  status        String   @default("backlog") // "backlog" | "todo" | "in_progress" | "in_review" | "testing" | "done"
  priority      String   @default("medium")  // "lowest" | "low" | "medium" | "high" | "highest" | "critical"
  storyPoints   Int?     @map("story_points")
  position      Int      @default(0)
  dueDate       DateTime? @map("due_date")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  resolvedAt    DateTime? @map("resolved_at")

  project     Project           @relation(fields: [projectId], references: [id])
  issueType   IssueType         @relation(fields: [issueTypeId], references: [id])
  epic        Epic?             @relation(fields: [epicId], references: [id])
  sprint      Sprint?           @relation(fields: [sprintId], references: [id])
  assignee    User?             @relation("IssueAssignee", fields: [assigneeId], references: [id])
  reporter    User              @relation("IssueReporter", fields: [reporterId], references: [id])
  parent      Issue?            @relation("IssueHierarchy", fields: [parentId], references: [id])
  subtasks    Issue[]           @relation("IssueHierarchy")
  comments    IssueComment[]
  attachments IssueAttachment[]
  activityLog IssueActivityLog[]
  tags        IssueTagRelation[]
  bugs        Bug[]

  @@unique([projectId, issueNumber])
  @@index([projectId])
  @@index([projectId, status])
  @@index([projectId, sprintId])
  @@index([projectId, assigneeId])
  @@index([projectId, priority])
  @@index([projectId, createdAt(sort: Desc)])
  @@map("issues")
}

model IssueTag {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  color     String?

  project Project            @relation(fields: [projectId], references: [id])
  issues  IssueTagRelation[]

  @@unique([projectId, name])
  @@map("issue_tags")
}

model IssueTagRelation {
  issueId String @map("issue_id")
  tagId   String @map("tag_id")

  issue Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  tag   IssueTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([issueId, tagId])
  @@map("issue_tag_relations")
}

model IssueComment {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  authorId  String   @map("author_id")
  content   String   @db.Text
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([issueId])
  @@map("issue_comments")
}

model IssueAttachment {
  id         String   @id @default(uuid())
  issueId    String   @map("issue_id")
  uploaderId String   @map("uploader_id")
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  mimeType   String   @map("mime_type")
  fileSize   BigInt   @map("file_size")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploaderId], references: [id])

  @@index([issueId])
  @@map("issue_attachments")
}

model IssueActivityLog {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  userId    String   @map("user_id")
  action    String   // "created" | "updated" | "status_changed" | "assigned" | "commented"
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([issueId])
  @@map("issue_activity_log")
}

// ==================== TEST MANAGEMENT ====================

model TestSuite {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  description String?
  status      String   @default("active") // "active" | "archived"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project   Project    @relation(fields: [projectId], references: [id])
  testCases TestCase[]
  testRuns  TestRun[]

  @@index([projectId])
  @@map("test_suites")
}

model TestCase {
  id             String   @id @default(uuid())
  testSuiteId    String   @map("test_suite_id")
  projectId      String   @map("project_id")
  title          String
  description    String?  @db.Text
  preconditions  String?  @db.Text
  steps          String?  @db.Text
  expectedResult String?  @map("expected_result") @db.Text
  priority       String   @default("medium") // "low" | "medium" | "high" | "critical"
  status         String   @default("draft")  // "draft" | "ready" | "deprecated"
  authorId       String   @map("author_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  testSuite TestSuite @relation(fields: [testSuiteId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
  author    User      @relation(fields: [authorId], references: [id])
  results   TestResult[]

  @@index([testSuiteId])
  @@index([projectId])
  @@map("test_cases")
}

model TestRun {
  id          String    @id @default(uuid())
  testSuiteId String    @map("test_suite_id")
  sprintId    String?   @map("sprint_id")
  executorId  String    @map("executor_id")
  name        String
  status      String    @default("planned") // "planned" | "in_progress" | "passed" | "failed" | "blocked"
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  testSuite TestSuite    @relation(fields: [testSuiteId], references: [id])
  sprint    Sprint?      @relation(fields: [sprintId], references: [id])
  executor  User?        @relation("TestRunExecutor", fields: [executorId], references: [id])
  results   TestResult[]

  @@index([testSuiteId])
  @@map("test_runs")
}

model TestResult {
  id          String    @id @default(uuid())
  testRunId   String    @map("test_run_id")
  testCaseId  String    @map("test_case_id")
  status      String    // "pass" | "fail" | "blocked" | "skipped"
  actualResult String?  @map("actual_result") @db.Text
  notes       String?   @db.Text
  executedBy  String    @map("executed_by")
  executedAt  DateTime  @default(now()) @map("executed_at")

  testRun  TestRun  @relation(fields: [testRunId], references: [id])
  testCase TestCase @relation(fields: [testCaseId], references: [id])
  executor User     @relation("TestExecutor", fields: [executedBy], references: [id])
  bug      Bug?

  @@index([testRunId])
  @@index([testCaseId])
  @@map("test_results")
}

// ==================== BUGS / DEFECTS ====================

model Bug {
  id            String    @id @default(uuid())
  projectId     String    @map("project_id")
  testResultId  String?   @unique @map("test_result_id")
  issueId       String?   @map("issue_id")
  title         String
  description   String?   @db.Text
  stepsToReproduce String? @map("steps_to_reproduce") @db.Text
  severity      String    @default("medium") // "low" | "medium" | "high" | "critical" | "blocker"
  status        String    @default("open")   // "open" | "in_progress" | "fixed" | "verified" | "rejected" | "closed"
  environment   String?
  reporterId    String    @map("reporter_id")
  assigneeId    String?   @map("assignee_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  resolvedAt    DateTime? @map("resolved_at")

  project    Project         @relation(fields: [projectId], references: [id])
  testResult TestResult?     @relation(fields: [testResultId], references: [id])
  issue      Issue?          @relation(fields: [issueId], references: [id])
  reporter   User            @relation("BugReporter", fields: [reporterId], references: [id])
  assignee   User?           @relation("BugAssignee", fields: [assigneeId], references: [id])
  attachments BugAttachment[]

  @@index([projectId])
  @@index([projectId, status])
  @@map("bugs")
}

model BugAttachment {
  id         String   @id @default(uuid())
  bugId      String   @map("bug_id")
  uploaderId String   @map("uploader_id")
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  mimeType   String   @map("mime_type")
  fileSize   BigInt   @map("file_size")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  bug      Bug  @relation(fields: [bugId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploaderId], references: [id])

  @@index([bugId])
  @@map("bug_attachments")
}

// ==================== CI/CD & WEBHOOKS ====================

model CIPipeline {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  name          String
  provider      String   // "github" | "gitlab" | "bitbucket" | "jenkins"
  repositoryUrl String   @map("repository_url")
  branch        String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project Project        @relation(fields: [projectId], references: [id])
  runs    PipelineRun[]

  @@index([projectId])
  @@map("ci_pipelines")
}

model PipelineRun {
  id            String    @id @default(uuid())
  pipelineId    String    @map("pipeline_id")
  externalId    String    @map("external_id")
  commitSha     String    @map("commit_sha")
  commitMessage String?   @map("commit_message") @db.Text
  branch        String
  status        String    @default("queued") // "queued" | "running" | "success" | "failed" | "cancelled"
  durationSeconds Int?    @map("duration_seconds")
  logsUrl       String?   @map("logs_url")
  startedAt     DateTime? @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  pipeline CIPipeline      @relation(fields: [pipelineId], references: [id])
  stages   PipelineStage[]

  @@index([pipelineId])
  @@index([pipelineId, status])
  @@map("pipeline_runs")
}

model PipelineStage {
  id              String    @id @default(uuid())
  pipelineRunId   String    @map("pipeline_run_id")
  name            String    // "build" | "test" | "deploy"
  status          String    @default("pending") // "pending" | "running" | "success" | "failed" | "skipped"
  durationSeconds Int?      @map("duration_seconds")
  position        Int       @default(0)
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")

  pipelineRun PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)

  @@index([pipelineRunId])
  @@map("pipeline_stages")
}

model Webhook {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  url       String
  secret    String
  events    String   // comma-separated: "issue.created,sprint.completed,..."
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project    Project            @relation(fields: [projectId], references: [id])
  deliveries WebhookDelivery[]

  @@index([projectId])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String   @id @default(uuid())
  webhookId    String   @map("webhook_id")
  eventType    String   @map("event_type")
  payload      String   @db.Text
  statusCode   Int?     @map("status_code")
  responseBody String?  @map("response_body") @db.Text
  status       String   @default("pending") // "pending" | "delivered" | "failed" | "retrying"
  retryCount   Int      @default(0) @map("retry_count")
  createdAt    DateTime @default(now()) @map("created_at")
  deliveredAt  DateTime? @map("delivered_at")

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_deliveries")
}

// ==================== ACTIVITY & AUDIT ====================

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  projectId  String   @map("project_id")
  entityType String   @map("entity_type") // "issue" | "sprint" | "document" | "test_case" | "bug"
  entityId   String   @map("entity_id")
  action     String
  details    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([projectId, entityType])
  @@index([createdAt(sort: Desc)])
  @@map("activity_logs")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String   // "mention" | "assignment" | "status_change" | "comment"
  title      String
  body       String?  @db.Text
  isRead     Boolean  @default(false) @map("is_read")
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}
