# Database
POSTGRES_USER=sdlc
POSTGRES_PASSWORD=sdlc_secret
POSTGRES_DB=sdlc_platform
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sdlc:sdlc_secret@localhost:5433/sdlc_platform?schema=public

# Redis
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379
REDIS_URL=redis://:redis_secret@localhost:6379

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret
MINIO_BUCKET=sdlc-uploads
MINIO_USE_SSL=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
